<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="WalletButtonBase">
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingLeft">18dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingRight">18dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="WalletButtonPrimary" parent="@style/WalletButtonBase">
        <item name="android:textColor">#FFF7ED</item>
        <item name="android:background">@drawable/wallet_button_primary</item>
    </style>

    <style name="WalletButtonSecondary" parent="@style/WalletButtonBase">
        <item name="android:textColor">#334155</item>
        <item name="android:background">@drawable/wallet_button_secondary</item>
    </style>

</resources>
