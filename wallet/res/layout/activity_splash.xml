<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- Full-screen splash background image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/splash_bg"
        android:contentDescription="@null" />

    <!-- Dark scrim so text pops over whatever is behind it -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#55000000" />

    <!-- Top block: brand mark + tagline -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DOBBSCOIN"
            android:textColor="#39FF14"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat"
            android:textSize="42sp"
            android:letterSpacing="0.08"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="6" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_marginTop="6dp"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:gravity="center"
            android:maxLines="2"
            android:text="Where SubCulture\nBecomes Capital"
            android:textColor="#FFD700"
            android:textStyle="italic"
            android:fontFamily="@font/caladea"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="14sp"
            android:autoSizeMaxTextSize="44sp"
            android:letterSpacing="0.02"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="8" />

    </LinearLayout>

    <!-- LOADING block — floats in the vertical center -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingLeft="48dp"
        android:paddingRight="48dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOADING..."
            android:textColor="#39FF14"
            android:textStyle="bold"
            android:textSize="22sp"
            android:letterSpacing="0.15"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="6"
            android:layout_marginBottom="10dp" />

        <ProgressBar
            android:id="@+id/splash_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_retro_green" />

    </LinearLayout>

    <!-- Bottom block — ordained button + tagline + copyright -->
    <LinearLayout
        android:id="@+id/splash_bottom_block"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="56dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingLeft="24dp"
        android:paddingRight="24dp">

        <Button
            android:id="@+id/btn_ordained"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="BECOME AN ORDAINED MINISTER"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_ordained_bg"
            android:textStyle="bold"
            android:textSize="15sp"
            android:letterSpacing="0.05"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="YOU'LL NEVER GET A BETTER DEAL"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:textSize="13sp"
            android:letterSpacing="0.08"
            android:gravity="center"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="4" />

        <TextView
            android:id="@+id/splash_copyright"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingTop="6dp"
            android:text="© SubGenius Finance"
            android:textColor="#FFD700"
            android:textSize="12sp"
            android:gravity="end"
            android:clickable="true"
            android:focusable="true"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingBottom="6dp"
            android:text="© 1978-2026 The SubGenius Foundation"
            android:textColor="#FFD700"
            android:textSize="12sp"
            android:gravity="end"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3" />

    </LinearLayout>

</RelativeLayout>
